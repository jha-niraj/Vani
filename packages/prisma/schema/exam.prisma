// ============================================================================
// EXAM CONTENT & LEARNING MODELS
// Contains all exam structure, questions, and mock test related models
// User-related models are in schema.prisma
// ============================================================================

// ============================================================================
// ENUMS FOR EXAM CONTENT
// ============================================================================

enum ExamPhaseType {
    MCQ
    WRITTEN
    INTERVIEW
}

enum QuestionDifficulty {
    EASY
    MEDIUM
    HARD
}

// ============================================================================
// EXAM STRUCTURE MODELS
// ============================================================================

model ExamType {
    id              String      @id @default(cuid())
    
    name            String      // e.g., "Loksewa"
    nameNp          String?     // Nepali name
    description     String?
    descriptionNp   String?
    
    icon            String?     // Icon name or URL
    order           Int         @default(0)
    isActive        Boolean     @default(true)
    
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt
    
    // Relations
    levels          ExamLevel[]
    users           User[]      @relation("UserCurrentExam")
    
    @@index([isActive])
}

model ExamLevel {
    id              String      @id @default(cuid())
    
    examTypeId      String
    examType        ExamType    @relation(fields: [examTypeId], references: [id], onDelete: Cascade)
    
    name            String      // e.g., "Na.Su. (Nayab Subba/Kharidar)"
    nameNp          String?
    description     String?
    descriptionNp   String?
    code            String?     // Short code like "NASU", "SO"
    
    icon            String?
    order           Int         @default(0)
    isActive        Boolean     @default(true)
    
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt
    
    // Relations
    phases          ExamPhase[]
    subjects        Subject[]
    users           User[]      @relation("UserCurrentLevel")
    mockTests       MockTest[]
    
    @@unique([examTypeId, code])
    @@index([examTypeId])
    @@index([isActive])
}

model ExamPhase {
    id              String          @id @default(cuid())
    
    examLevelId     String
    examLevel       ExamLevel       @relation(fields: [examLevelId], references: [id], onDelete: Cascade)
    
    name            String          // e.g., "Phase 1", "Phase 2"
    nameNp          String?
    description     String?
    type            ExamPhaseType
    
    order           Int             @default(0)
    isActive        Boolean         @default(true)
    
    createdAt       DateTime        @default(now())
    updatedAt       DateTime        @updatedAt
    
    @@index([examLevelId])
    @@index([type])
}

// ============================================================================
// SUBJECT & TOPIC MODELS
// ============================================================================

model Subject {
    id              String      @id @default(cuid())
    
    examLevelId     String
    examLevel       ExamLevel   @relation(fields: [examLevelId], references: [id], onDelete: Cascade)
    
    name            String      // e.g., "General Knowledge"
    nameNp          String?
    description     String?
    
    icon            String?
    color           String?     // Hex color for UI
    order           Int         @default(0)
    isActive        Boolean     @default(true)
    
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt
    
    // Relations
    topics          Topic[]
    questions       Question[]
    
    @@index([examLevelId])
    @@index([isActive])
}

model Topic {
    id              String      @id @default(cuid())
    
    subjectId       String
    subject         Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
    
    parentTopicId   String?
    parentTopic     Topic?      @relation("SubTopics", fields: [parentTopicId], references: [id])
    
    name            String      // e.g., "Rana Period"
    nameNp          String?
    description     String?
    
    order           Int         @default(0)
    isActive        Boolean     @default(true)
    
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt
    
    // Relations
    subTopics       Topic[]     @relation("SubTopics")
    questions       Question[]
    
    @@index([subjectId])
    @@index([parentTopicId])
    @@index([isActive])
}

// ============================================================================
// QUESTION MODELS
// ============================================================================

model Question {
    id              String              @id @default(cuid())
    
    subjectId       String
    subject         Subject             @relation(fields: [subjectId], references: [id], onDelete: Cascade)
    
    topicId         String
    topic           Topic               @relation(fields: [topicId], references: [id], onDelete: Cascade)
    
    // Question content
    question        String
    questionNp      String?
    
    // Options (stored as JSON for flexibility)
    options         Json                // { a: "...", b: "...", c: "...", d: "..." }
    optionsNp       Json?
    
    correctAnswer   String              // 'a', 'b', 'c', or 'd'
    
    // Explanation
    explanation     String?
    explanationNp   String?
    
    // Metadata
    difficulty      QuestionDifficulty  @default(MEDIUM)
    source          String?             // e.g., "PSC 2079", "Model Question"
    tags            String[]            @default([])
    
    // AI Generated
    isAIGenerated   Boolean             @default(false)
    isVerified      Boolean             @default(false)
    verifiedBy      String?
    verifiedAt      DateTime?
    
    // Statistics (updated periodically)
    attemptCount    Int                 @default(0)
    correctCount    Int                 @default(0)
    avgTimeSeconds  Float?
    
    isActive        Boolean             @default(true)
    
    createdAt       DateTime            @default(now())
    updatedAt       DateTime            @updatedAt
    
    // Relations
    attempts        QuestionAttempt[]
    bookmarks       Bookmark[]
    mockTestQuestions MockTestQuestion[]
    
    @@index([subjectId])
    @@index([topicId])
    @@index([difficulty])
    @@index([isActive, isVerified])
}

// ============================================================================
// MOCK TEST MODELS
// ============================================================================

model MockTest {
    id                  String      @id @default(cuid())
    
    examLevelId         String
    examLevel           ExamLevel   @relation(fields: [examLevelId], references: [id], onDelete: Cascade)
    
    name                String
    nameNp              String?
    description         String?
    
    totalQuestions      Int         @default(100)
    durationMinutes     Int         @default(120)
    negativeMarking     Boolean     @default(true)
    negativeMarkValue   Float       @default(0.25)
    
    // Subject distribution (JSON)
    // Format: { "subjectId": 25, "subjectId2": 20, ... }
    subjectDistribution Json        @default("{}")
    
    isActive            Boolean     @default(true)
    
    createdAt           DateTime    @default(now())
    updatedAt           DateTime    @updatedAt
    
    // Relations
    questions           MockTestQuestion[]
    results             MockTestResult[]
    
    @@index([examLevelId])
    @@index([isActive])
}

model MockTestQuestion {
    id              String      @id @default(cuid())
    
    mockTestId      String
    mockTest        MockTest    @relation(fields: [mockTestId], references: [id], onDelete: Cascade)
    
    questionId      String
    question        Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
    
    order           Int
    
    @@unique([mockTestId, questionId])
    @@unique([mockTestId, order])
    @@index([mockTestId])
}

// ============================================================================
// USER LEARNING PROGRESS MODELS
// These track user's progress, attempts, and results on exams
// ============================================================================

model UserProgress {
    id                      String      @id @default(cuid())
    
    userId                  String      @unique
    user                    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    
    // Overall Stats
    totalQuestionsAttempted Int         @default(0)
    totalCorrect            Int         @default(0)
    totalIncorrect          Int         @default(0)
    totalSkipped            Int         @default(0)
    totalTimeSpentSeconds   Int         @default(0)
    
    // Streak
    currentStreak           Int         @default(0)
    longestStreak           Int         @default(0)
    lastPracticeDate        DateTime?
    
    // Subject-wise progress (JSON for flexibility)
    // Format: { "subjectId": { attempted: 100, correct: 80, ... } }
    subjectProgress         Json        @default("{}")
    
    // Topic-wise progress
    topicProgress           Json        @default("{}")
    
    createdAt               DateTime    @default(now())
    updatedAt               DateTime    @updatedAt
    
    @@index([userId])
}

model DailyProgress {
    id                  String      @id @default(cuid())
    
    userId              String
    user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    
    date                DateTime    @db.Date
    
    questionsCompleted  Int         @default(0)
    questionsCorrect    Int         @default(0)
    goal                Int         @default(25)
    goalMet             Boolean     @default(false)
    timeSpentSeconds    Int         @default(0)
    
    createdAt           DateTime    @default(now())
    updatedAt           DateTime    @updatedAt
    
    @@unique([userId, date])
    @@index([userId, date])
}

model QuestionAttempt {
    id              String      @id @default(cuid())
    
    userId          String
    user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    
    questionId      String
    question        Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
    
    selectedAnswer  String?     // 'a', 'b', 'c', 'd', or null if skipped
    isCorrect       Boolean
    isSkipped       Boolean     @default(false)
    
    timeTakenSeconds Int?
    
    // Context
    sessionType     String?     // 'practice', 'mock_test', 'quick_quiz'
    mockTestId      String?
    
    attemptedAt     DateTime    @default(now())
    
    @@index([userId, questionId])
    @@index([userId, attemptedAt])
    @@index([questionId])
}

model Bookmark {
    id              String      @id @default(cuid())
    
    userId          String
    user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    
    questionId      String
    question        Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
    
    note            String?     // Optional user note
    
    createdAt       DateTime    @default(now())
    
    @@unique([userId, questionId])
    @@index([userId])
}

model MockTestResult {
    id                  String      @id @default(cuid())
    
    userId              String
    user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    
    mockTestId          String
    mockTest            MockTest    @relation(fields: [mockTestId], references: [id], onDelete: Cascade)
    
    // Timing
    startedAt           DateTime
    completedAt         DateTime?
    timeTakenSeconds    Int?
    
    // Results
    totalQuestions      Int
    attempted           Int         @default(0)
    correct             Int         @default(0)
    incorrect           Int         @default(0)
    skipped             Int         @default(0)
    
    score               Float?
    percentage          Float?
    
    // Subject-wise breakdown (JSON)
    subjectWiseScore    Json        @default("{}")
    
    // Individual question results (JSON array)
    questionResults     Json        @default("[]")
    
    createdAt           DateTime    @default(now())
    
    @@index([userId])
    @@index([mockTestId])
    @@index([userId, completedAt])
}

// ============================================================================
// SYSTEM CONFIG MODEL
// ============================================================================

model AppConfig {
    id              String      @id @default(cuid())
    
    key             String      @unique
    value           Json
    description     String?
    
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt
}