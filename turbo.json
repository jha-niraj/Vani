{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "tui",
	"globalEnv": [
		"NODE_ENV",
		"DATABASE_URL",
		"NEXTAUTH_URL",
		"NEXTAUTH_SECRET",
		"RESEND_API_KEY",
		"AUTH_FROM_EMAIL",
		"SARVAM_API_KEY",
		"OPENAI_API_KEY",
		"SUPABASE_ACCESS_KEY_ID",
		"SUPABASE_SECRET_ACCESS_KEY",
		"SUPABASE_REGION",
		"SUPABASE_STORAGE_ENDPOINT",
		"SUPABASE_S3_BUCKET_NAME"
	],
	"tasks": {
		"generate": {
			"cache": false,
			"inputs": [
				"prisma/schema.prisma"
			],
			"outputs": [
				"../../node_modules/.prisma/client/**"
			]
		},
		"build": {
			"dependsOn": [
				"^generate",
				"^build"
			],
			"env": [
				"NODE_ENV",
				"DATABASE_URL",
				"NEXTAUTH_URL",
				"NEXTAUTH_SECRET",
				"RESEND_API_KEY",
				"AUTH_FROM_EMAIL",
				"SARVAM_API_KEY",
				"OPENAI_API_KEY",
				"SUPABASE_ACCESS_KEY_ID",
				"SUPABASE_SECRET_ACCESS_KEY",
				"SUPABASE_REGION",
				"SUPABASE_STORAGE_ENDPOINT",
				"SUPABASE_S3_BUCKET_NAME"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*"
			],
			"outputs": [
				".next/**",
				"!.next/cache/**"
			]
		},
		"lint": {
			"dependsOn": [
				"^lint"
			]
		},
		"check-types": {
			"dependsOn": [
				"^check-types"
			]
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"env": [
				"NODE_ENV",
				"DATABASE_URL",
				"NEXTAUTH_URL",
				"NEXTAUTH_SECRET",
				"RESEND_API_KEY",
				"AUTH_FROM_EMAIL",
				"SARVAM_API_KEY",
				"OPENAI_API_KEY",
				"SUPABASE_ACCESS_KEY_ID",
				"SUPABASE_SECRET_ACCESS_KEY",
				"SUPABASE_REGION",
				"SUPABASE_STORAGE_ENDPOINT",
				"SUPABASE_S3_BUCKET_NAME"
			]
		}
	}
}